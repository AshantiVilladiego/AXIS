# --- Database Configuration ---
# Format:
# postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=

# SSL Certificate (leave as-is unless instructed otherwise)
SSL_CERT_FILE="certs/prod-ca-2021.crt"
DB_SSL_VERIFY=false

# Default development user UUID (for local testing only)
DEFAULT_DEV_USER_ID=

# Supabase JWT Secret (used for verifying JWT tokens)
SUPABASE_JWT_SECRET=

# Supabase Service Role Key (server-side only)
SERVICE_ROLE_KEY=

# AI Provider API Keys
GEMINI_API_KEY=
GROQ_API_KEY=
HF_API_KEY=

# --- Application Settings ---
DEBUG=True
PORT=8000